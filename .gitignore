# George 3 git ignore rules.
# Purpose: Keep local secrets, caches, and runtime output out of git.
# Phase: Foundation.
# Last updated: 2026-05-31.
# Notes: `.env` must remain local only.

# Local environment
.env

# Python
__pycache__/
*.py[cod]
.pytest_cache/

# macOS
.DS_Store

# Local runtime output
logs/*
data/*

!logs/.gitkeep
!data/.gitkeep
